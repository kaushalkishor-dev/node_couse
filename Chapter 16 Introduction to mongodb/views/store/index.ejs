<%- include('../partials/head.ejs') %>
</head>
<body class="bg-gray-100">
  <%- include('../partials/nav') %>
    <header class="bg-white shadow">
      <h1>Welcome to airbnb</h1>
    </header>
    
    </main >
    <main class="max-w-7xl mx-auto px-4 py-12">
    <span>Wellcome to airbnb Index Page </span> <br>
    <ul >
      <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <% registeredHomes.forEach(home => { %>
          <li class="bg-white rounded-lg shadow-md overflow-hidden">
            <img src="<%= home.photoUrl %>" alt="<%= home.houseName %>" class="w-full h-48 object-cover">
            <div class="p-4">
              <h3 class="text-lg font-semibold">Name: <%= home.houseName %></h3>
              <p class="text-gray-600">Location: <%= home.location %></p>
              <p class="text-gray-600">Price: $<%= home.price %></p>
              <p class="text-gray-600">Rating: <%= home.rating %> ⭐</p>
            </div>
            <div>
            <button class="bg-green-500 text-white py-2 px-4 rounded-md hover:bg-green-600">Book Now</button>
          </div>
            
          </li>
          
        <% }) %>
      </ul>
    </ul>

    
  </body>
</html>
