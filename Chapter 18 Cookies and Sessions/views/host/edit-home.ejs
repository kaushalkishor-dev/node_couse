<%- include('../partials/head.ejs') %>
</head>
<body>
  <%- include('../partials/nav') %>
    <header>
      <h1> <%= editing ? "Edit" : "Register"%> Your Home Here :</h1>
    </header>
    <main class="flex items-center justify-center bg-gray-100">
      <form action="/host/<%= editing ? "edit-home" : "add-home" %>" method="POST" class="bg-white p-8 rounded-lg shadow-md w-full max-w-md">
        <input 
        type="hidden" 
        name="id" 
        value="<%= editing ? home._id : ''  %>" 
      />
      <input
        type="text"
        name="houseName"
        value="<%= editing ? home.houseName : ''  %>"
        placeholder="Enter the name of your house"
        class="w-full px-4 py-2 mb-4 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
      />
      <input
        type="text"
        name="price"
        value="<%= editing ? home.price : ''  %>"
        placeholder="Price per night"
        class="w-full px-4 py-2 mb-4 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
      />
      <input
        type="text"
        name="location"
        value="<%= editing ? home.location: ''  %>"
        placeholder="location"
        class="w-full px-4 py-2 mb-4 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
      />
      <input
        type="text"
        name="rating"
        value="<%= editing ? home.rating : ''  %>"
        placeholder="Rating"
        class="w-full px-4 py-2 mb-4 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
      />
      <input
        type="text"
        name="photoUrl"
        value="<%= editing ? home.photoUrl : ''  %>"
        placeholder="Enter the photo url of your house"
        class="w-full px-4 py-2 mb-4 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
      />
      <textarea
        type="text"
        name="description"
        placeholder="Enter description of your house"
        class="w-full px-4 py-2 mb-4 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
      ><%= editing ? home.description : ''  %></textarea>
      <input type="submit" value="<%= editing ? "Update " : "Register Home" %>" class="w-full px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition" />
      </form>
    </main>
  </body>
</html>
